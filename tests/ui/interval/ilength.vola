//BEGIN-CONFIG
//EXEC-FN:call
//EXEC-ARGS:-2.0,3.0
//EXEC-EPS:0.001
//EXEC-RES:0.0,3.7024
//END-CONFIG

export fn call(a: real, b: real) -> vec2{
    //This describes a rectangle [-2, 0.0] to [1.0, 3.0]
    // The _real_ interval would be 1..sqrt(13). However
    // our (tight-ish) approximation comes up with 0 .. 3.7
    let start = [a, 0.0];
    let end = [1.0, b];
    let c = length([start .. end]);
    [c.start, c.end]
}
