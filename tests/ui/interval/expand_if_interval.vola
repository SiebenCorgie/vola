//BEGIN-CONFIG
//EXEC-FN:call
//EXEC-ARGS:2.0,1.5
//EXEC-EPS:0.0
//EXEC-RES:-1.0,1.0
//END-CONFIG

export fn call(p: real, a: real) -> vec2{

    let t = 0.0;

    if a > 1.0{
        t = t + sin(p);
    }else{
        t = 3.0 + tan(p) - p;
    }

    let ai = bound(t, p, [-INF..INF]);
    [ai.start, ai.end]
}
