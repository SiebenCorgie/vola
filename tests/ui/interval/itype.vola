//BEGIN-CONFIG
//EXEC-FN:call
//EXEC-ARGS:0.0
//EXEC-EPS:0.0
//EXEC-RES:0.0
//END-CONFIG

fn sub_function(i: interval<vec3<real>>) -> real{
    i.x.start + i.y.end
}

export fn call(p: real) -> real{
    let a = [sin(p); 3];

    let ai = bound(a, p, [-INF..INF]);
    //NOTE: This checks that the interval-in-fn-call process functions
    sub_function(ai)
}
